{
  "name": "worklog",
  "version": "0.1.0",
  "private": true,
  "main": "electron-main.js",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "electron .",
    "electron:build": "next build --webpack && electron-builder --mac"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@google/design.md": "^0.1.1",
    "@supabase/supabase-js": "^2.104.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.worklog.auto",
    "productName": "WorkLogAuto",
    "files": [
      "electron-main.js",
      "package.json",
      "public/**/*",
      "data/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": ".next",
        "to": "app/.next"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "public/app.icns"
    },
    "directories": {
      "output": "dist-electron"
    },
    "asar": false
  }
}
